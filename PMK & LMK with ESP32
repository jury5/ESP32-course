#include <esp_now.h>
#include <WiFi.h>

// المفاتيح (يجب أن تكون 16 حرفاً/بايت بالضبط)
const char* my_pmk = "pmk_password_123"; // Primary Master Key
const char* my_lmk = "lmk_password_456"; // Local Master Key

uint8_t peerAddress[] = {0x24, 0x0A, 0xC4, 0xXX, 0xXX, 0xXX}; // عنوان الطرف الآخر

void setup() {
  Serial.begin(115200);
  WiFi.mode(WIFI_STA);

  if (esp_now_init() != ESP_OK) {
    Serial.println("Error initializing ESP-NOW");
    return;
  }

  // 1. ضبط الـ PMK
  esp_now_set_pmk((uint8_t *)my_pmk);

  // 2. إعداد بيانات الطرف الآخر (Peer) مع التشفير
  esp_now_peer_info_t peerInfo = {};
  memcpy(peerInfo.peer_addr, peerAddress, 6);
  peerInfo.channel = 0;  
  
  // ضبط الـ LMK وتفعيل التشفير
  memcpy(peerInfo.lmk, my_lmk, 16);
  peerInfo.encrypt = true; // تفعيل التشفير

  if (esp_now_add_peer(&peerInfo) != ESP_OK) {
    Serial.println("Failed to add peer");
    return;
  }
}

void loop() {
  const char* msg = "Secure Data";
  esp_now_send(peerAddress, (uint8_t *)msg, strlen(msg));
  delay(2000);
}
