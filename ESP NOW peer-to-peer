#include <esp_now.h>
#include <WiFi.h>

// Put the MAC Address of the OTHER device here
uint8_t peerAddress[] = {0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF};

// Runs when a message is received
void OnDataRecv(const uint8_t * mac, const uint8_t *data, int len) {
  Serial.print("Friend: ");
  Serial.write(data, len); 
  Serial.println();
}

void setup() {
  Serial.begin(115200);
  WiFi.mode(WIFI_STA);
  esp_now_init();

  // Link the receive function
  esp_now_register_recv_cb(esp_now_recv_cb_t(OnDataRecv));

  // Add the other device
  esp_now_peer_info_t peerInfo = {};
  memcpy(peerInfo.peer_addr, peerAddress, 6);
  esp_now_add_peer(&peerInfo);
}

void loop() {
  if (Serial.available() > 0) {
    String msg = Serial.readStringUntil('\n');
    
    // Send message to the peer
    esp_now_send(peerAddress, (uint8_t *)msg.c_str(), msg.length());
    
    Serial.println("You: " + msg);
  }
}
