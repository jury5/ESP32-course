// كود المرسل
//  هذا الجهاز سينتظر منك كتابة رسالة في الـسيريال مونيتور ، ثم يرسلها فور ضغطك على انتر
#include <esp_now.h>
#include <WiFi.h>

// ضع عنوان MAC الخاص بالمستقبل هنا
uint8_t address[] = {0x24, 0x0A, 0xC4, 0xAE, 0x12, 0x34}; 

void setup() {
  Serial.begin(115200);
  WiFi.mode(WIFI_STA); // تفعيل الواي فاي
  esp_now_init();      // تشغيل البروتوكول

  // إضافة المستقبل (Peer)
  esp_now_peer_info_t peer = {};
  memcpy(peer.peer_addr, address, 6);
  esp_now_add_peer(&peer);
}

void loop() {
  if (Serial.available() > 0) {
    String msg = Serial.readStringUntil('\n');
    
    // إرسال الرسالة مباشرة
    esp_now_send(address, (uint8_t *) msg.c_str(), msg.length());
    
    Serial.println("تم الإرسال: " + msg);
  }
}




// كود المستقبل
// هذا الجهاز سيظل في حالة "استماع" دائم، وبمجرد وصول رسالة، سيقوم بطباعتها فوراً.
#include <esp_now.h>
#include <WiFi.h>

// دالة الاستقبال: تحول البيانات لنص وتطبعه
void OnDataRecv(const uint8_t * mac, const uint8_t *data, int len) {
  char msg[len + 1];
  memcpy(msg, data, len);
  msg[len] = '\0'; // إنهاء النص

  Serial.println(msg); 
}

void setup() {
  Serial.begin(115200);
  WiFi.mode(WIFI_STA);
  esp_now_init(); // تشغيل البروتوكول

  // ربط الاستقبال بالدالة أعلاه
  esp_now_register_recv_cb(esp_now_recv_cb_t(OnDataRecv));
}

void loop() {
  // الاستقبال يعمل تلقائياً في الخلفية
}
