#include <ESP32Servo.h>
#include <WiFi.h>
#include <ESPAsyncWebServer.h> // مكتبة قوية قادرة على تمكين نقل البيانات بسرعة عالية.

//تعريف دبابيس التوصيل
int trigPin = 5;
int echoPin = 18;
int laserPin = 21;
int servoPin = 19;

//تعريف المتغيرات والكائنات
WiFiServer server(80);
Servo myServo;             // إنشاء كائن للتحكم في محرك السيرفو.
int currentAngle = 0;      // متغير لتخزين زاوية المحرك الحالية (يبدأ من الصفر)
int stepAmount = 10;       // مقدار الخطوة التي يتحركها المحرك في كل مرة (10 درجات) لمنع الاهتزاز
long distance;             // متغير لتخزين المسافة المحسوبة بواسطة الحساس

void setup() {
  Serial.begin(115200);
  
  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);
  pinMode(laserPin, OUTPUT);
  myServo.attach(servoPin);     //تعريف منفذ التحكم في محرك السيرفو وربطه بالمنفذ رقم 19

void loop() {
readSensor();   // استدعاء وظيفة قراءة الحساس لتحديث قيمة المسافة في كل دورة للبرنامج

}

void readSensor() {
  digitalWrite(trigPin, LOW);        // التأكد من إيقاف الإشارة تماماً لمدة ميكروثانيتين
  delayMicroseconds(2);
  digitalWrite(trigPin, HIGH);       // إرسال نبضة صوتية مدتها 10 ميكروثانية
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);        // إيقاف الإرسال والبدء بانتظار العودة
  
  long duration = pulseIn(echoPin, HIGH); // قياس الزمن الذي استغرقه الصدى للعودة
  distance = duration * 0.034 / 2;        // تحويل الزمن إلى مسافة بالسنتيمتر (السرعة × الزمن ÷ 2)
  
  if (distance == 0) distance = 400;      // إذا كانت القراءة خاطئة (صفر)، نعتبرها مسافة بعيدة جداً لتجنب الأخطاء
}

void moveServo() {
  myServo.write(currentAngle);        // أمر المحرك بالتوجه إلى الزاوية الحالية
  
  currentAngle += stepAmount;         // زيادة الزاوية بمقدار الخطوة (مثلاً 10 درجات)

  // إذا وصل المحرك إلى النهاية (180 درجة) أو البداية (0 درجة)، قم بعكس اتجاه الحركة
  if (currentAngle <= 0 || currentAngle >= 180) {
    stepAmount = -stepAmount; 
  }
}

void fireLaser() {
  digitalWrite(laserPin, HIGH);       // إرسال تيار كهربائي لمنفذ الليزر لتشغيله
}
