#include <WiFi.h> // استدعاء مكتبة الواي فاي الضرورية للوصول لمعلومات الشبكة

void setup() {
  Serial.begin(115200);
  
  // تفعيل وضع المحطة (Station Mode)
  // هذا السطر ضروري لأن عنوان الماك مرتبط بوحدة الواي فاي، ويجب تشغيلها لقراءته
  WiFi.mode(WIFI_STA);
  
  Serial.println();
  Serial.println("------------------------------------------");
  Serial.print("ESP32 MAC Address: ");
  
  Serial.println(WiFi.macAddress());
  Serial.println("------------------------------------------");
}

void loop() {
  // لا نحتاج لكتابة أي شيء هنا لأننا نحتاج لمعرفة العنوان مرة واحدة فقط عند التشغيل
}
